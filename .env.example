# Slack 설정
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# 서버 설정
PORT=3000
NODE_ENV=development

# Tilko API 설정
TILKO_API_KEY=your-tilko-api-key
TILKO_AES_KEY=your-16-char-key

# 인터넷등기소 로그인 정보
IROS_USER_ID=your-iros-id
IROS_USER_PASSWORD=your-iros-password
IROS_PIN=your-default-pin
IROS_EMONEY_NO1=your-emoney-no1
IROS_EMONEY_NO2=your-emoney-no2
IROS_EMONEY_PASSWORD=your-emoney-password

# 정부24 로그인 정보 (건축물대장용)
EAIS_USER_ID=your-eais-id
EAIS_USER_PASSWORD=your-eais-password

# 공공데이터 API
PUBLIC_DATA_API_KEY=your-public-data-api-key

# Mock API 사용 여부
USE_MOCK_API=false

# 파일 저장 설정
FILE_RETENTION_DAYS=30
TEMP_FILE_PATH=./temp
